# Insight Agent environment configuration
# Fill in only the provider you want to use.

# Choose provider: openai, alibaba, or openrouter
# LLM_PROVIDER=openai
# LLM_PROVIDER=alibaba
# LLM_PROVIDER=openrouter

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini-2025-08-07
# OPENAI_REFLECT_MODEL=gpt-5
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=120
# OPENAI_PROJECT=
# OPENAI_ORGANIZATION=

# OpenRouter (OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_API_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://example.com
# OPENROUTER_APP_NAME=insight-agent
# OPENROUTER_TIMEOUT_SECONDS=180

# Alibaba Cloud Model Studio (DashScope OpenAI-compatible API)
DASHSCOPE_API_KEY=
ALIBABA_MODEL=qwen3-max
# ALIBABA_REFLECT_MODEL=qwen-max
# ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1
# ALIBABA_REGION=singapore
# ALIBABA_TIMEOUT_SECONDS=120