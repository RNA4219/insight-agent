# Insight Agent environment configuration
# Fill in the providers you want to use.

# Single provider
# LLM_PROVIDER=openai
# LLM_PROVIDER=alibaba
# LLM_PROVIDER=openrouter

# Multi-provider failover / round-robin
# LLM_PROVIDER_SEQUENCE=openai,openrouter,alibaba
# If LLM_PROVIDER_SEQUENCE is set, it takes precedence over LLM_PROVIDER.

# Stage-specific output caps (optional)
# LLM_MAX_TOKENS_ROUTING=500
# LLM_MAX_TOKENS_EXTRACTION=900
# LLM_MAX_TOKENS_DISCOVERY=1200
# LLM_MAX_TOKENS_EVALUATION=400
# LLM_MAX_TOKENS_CONSOLIDATION=900
# LLM_MAX_TOKENS_SUMMARY=1200
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_RETRIES=2
# LLM_RETRY_BACKOFF_SECONDS=0.5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini-2025-08-07
# OPENAI_REFLECT_MODEL=gpt-5
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=120
# OPENAI_PROJECT=
# OPENAI_ORGANIZATION=

# OpenRouter (OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_API_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://example.com
# OPENROUTER_APP_NAME=insight-agent
# OPENROUTER_TIMEOUT_SECONDS=180

# Alibaba Cloud Model Studio (DashScope OpenAI-compatible API)
DASHSCOPE_API_KEY=
ALIBABA_MODEL=qwen3-max
# ALIBABA_REFLECT_MODEL=qwen-max
# ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1
# ALIBABA_REGION=singapore
# ALIBABA_TIMEOUT_SECONDS=120
