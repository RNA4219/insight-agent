# memx-core local environment
# This file is auto-loaded by the mem CLI and API server when started under memx-core or its subdirectories.
# Fill in only the provider you want to use.

# Choose provider: openai, alibaba, or openrouter
# MEMX_LLM_PROVIDER=openai
# MEMX_LLM_PROVIDER=alibaba
# MEMX_LLM_PROVIDER=openrouter

# OpenAI
OPENAI_API_KEY=
MEMX_OPENAI_MODEL=gpt-5-mini
# MEMX_OPENAI_REFLECT_MODEL=gpt-5
# MEMX_OPENAI_BASE_URL=https://api.openai.com/v1
# MEMX_OPENAI_TIMEOUT_SECONDS=120
# OPENAI_PROJECT=
# OPENAI_ORGANIZATION=

# OpenRouter (OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_API_MODEL=openai/gpt-4.1-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://example.com
# OPENROUTER_APP_NAME=insight-agent
# OPENROUTER_TIMEOUT_SECONDS=180

# Alibaba Cloud Model Studio (DashScope OpenAI-compatible API)
DASHSCOPE_API_KEY=
MEMX_ALIBABA_MODEL=qwen3-max
# MEMX_ALIBABA_REFLECT_MODEL=qwen-max
# MEMX_ALIBABA_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1
# MEMX_ALIBABA_REGION=singapore
# MEMX_ALIBABA_TIMEOUT_SECONDS=120
